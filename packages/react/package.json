{
  "name": "@partylayer/react",
  "version": "0.9.5",
  "description": "React hooks and components for PartyLayer",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./query": {
      "types": "./dist/query.d.ts",
      "import": "./dist/query.mjs",
      "require": "./dist/query.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [
    "canton",
    "wallet",
    "react"
  ],
  "author": "PartyLayer Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PartyLayer/PartyLayer.git",
    "directory": "packages/react"
  },
  "homepage": "https://partylayer.xyz",
  "bugs": {
    "url": "https://github.com/PartyLayer/PartyLayer/issues"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "@tanstack/react-query": ">=5"
  },
  "dependencies": {
    "@partylayer/sdk": "workspace:^",
    "@partylayer/registry-client": "workspace:^",
    "@partylayer/session": "workspace:^",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@partylayer/testing": "workspace:^",
    "@tanstack/react-query": "^5.101.0",
    "@testing-library/react": "^14.2.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.11.0",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
