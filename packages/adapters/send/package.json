{
  "name": "@partylayer/adapter-send",
  "version": "1.2.1",
  "description": "Send Canton Wallet adapter for PartyLayer (CIP-0103, passkey-based via Sigilry)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [
    "partylayer",
    "canton",
    "send",
    "wallet",
    "adapter",
    "cip-0103",
    "sigilry",
    "passkey",
    "webauthn"
  ],
  "author": "PartyLayer Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PartyLayer/PartyLayer.git",
    "directory": "packages/adapters/send"
  },
  "homepage": "https://github.com/PartyLayer/PartyLayer#readme",
  "bugs": {
    "url": "https://github.com/PartyLayer/PartyLayer/issues"
  },
  "dependencies": {
    "@partylayer/core": "workspace:^",
    "@partylayer/provider": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
