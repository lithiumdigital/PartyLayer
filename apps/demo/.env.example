# PartyLayer Demo Environment Variables

# Registry server URL (default: http://localhost:3001)
NEXT_PUBLIC_REGISTRY_URL=http://localhost:3001

# Registry channel: stable or beta (default: stable)
NEXT_PUBLIC_REGISTRY_CHANNEL=stable

# Network: devnet, testnet, or mainnet (default: devnet)
NEXT_PUBLIC_NETWORK=devnet

# WalletConnect Cloud project id — used by the opt-in WalletConnect adapter so
# the "WalletConnect" option in the connect modal opens a scannable pairing QR.
# Falls back to a shared local-dev project id when unset (fine for the scan test).
NEXT_PUBLIC_WC_PROJECT_ID=577414f6b46f09a7383d3c306c013a57

# ── CIP-0104 cost-visibility demo (/cost-demo) ──────────────────────────────
# The backend proxy (/api/cost-estimate) reads a live pre-submission cost
# estimate from a Canton validator's JSON Ledger API. Leave these UNSET to run in
# fixture mode (a real captured DevNet estimate — the demo works with no node and
# CI needs no validator). Set all four to read from a live validator:
#   LEDGER_API_URL         — base URL of the validator JSON Ledger API (e.g. http://localhost:8080)
#   LEDGER_PARTY           — the validator party id (actAs / sole signatory)
#   LEDGER_SYNCHRONIZER_ID — the live global-domain synchronizer id
#   LEDGER_DSO_PARTY       — the DSO party id (used in the ValidatorRight create arguments)
# LEDGER_API_URL=
# LEDGER_PARTY=
# LEDGER_SYNCHRONIZER_ID=
# LEDGER_DSO_PARTY=
