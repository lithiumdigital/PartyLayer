{
  "name": "partylayer",
  "version": "0.1.0",
  "private": true,
  "description": "PartyLayer - CIP-0103 compliant wallet SDK for Canton Network",
  "repository": {
    "type": "git",
    "url": "https://github.com/PartyLayer/PartyLayer.git"
  },
  "homepage": "https://github.com/PartyLayer/PartyLayer#readme",
  "bugs": {
    "url": "https://github.com/PartyLayer/PartyLayer/issues"
  },
  "author": "PartyLayer Contributors",
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "dev": "pnpm --filter demo dev",
    "typecheck": "pnpm -r typecheck",
    "lint:workspace-protocol": "node scripts/check-workspace-protocol.mjs",
    "validate:publish": "node scripts/validate-publish.mjs",
    "registry:sign": "tsx scripts/registry/sign.ts",
    "registry:verify": "tsx scripts/registry/verify.ts",
    "verify:e2e": "tsx scripts/verify/e2e.ts",
    "gate": "pnpm gate:build && pnpm typecheck && pnpm lint && pnpm gate:test && pnpm gate:conformance && pnpm gate:api && pnpm gate:registry",
    "//gate:build": "Serial (--workspace-concurrency=1): the parallel -r build can start a dependent package (e.g. testing) before a workspace dep (session) has flushed its .d.ts, an intermittent DTS-resolution race; serial enforces topological order deterministically. Reinstall after dependency edits keeps the graph correct — this is belt-and-suspenders (cf. examples.yml serialization precedent).",
    "gate:build": "pnpm -r --filter \"@partylayer/*\" --workspace-concurrency=1 build",
    "gate:test": "CI=true pnpm -r test",
    "gate:conformance": "node scripts/gate/conformance-native.mjs",
    "gate:api": "node --test scripts/gate/api-normalize.test.mjs && node scripts/gate/api-snapshot.mjs",
    "gate:api:update": "node scripts/gate/api-snapshot.mjs --update",
    "gate:registry": "node scripts/gate/registry-check.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "keywords": [
    "canton",
    "wallet",
    "sdk",
    "dapp",
    "blockchain"
  ],
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@playwright/test": "^1.58.0",
    "ajv": "^8.17.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "commander": "^14.0.2",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "semver": "^7.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "dependencies": {
    "@types/express": "^4.17.25",
    "express": "^4.22.1"
  }
}
